# Azure SQL Database connection
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DATABASE=kinpoyo
AZURE_SQL_USER=your-username
AZURE_SQL_PASSWORD=your-password

# Local uploads dir (temporary working folder for received videos)
UPLOAD_DIR=./uploads

# Image saved every N frames within the selected range
# (pose data is always saved every frame)
IMAGE_SAMPLE_INTERVAL=10
